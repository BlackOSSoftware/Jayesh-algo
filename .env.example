# VPS / production settings
HOST=0.0.0.0
PORT=3000
NODE_ENV=production

# Linux VPS usually needs python3 (auto-detected if unset)
# ALGO_PYTHON=python3

# Disable Next.js telemetry (also set in npm scripts)
NEXT_TELEMETRY_DISABLED=1

# Use build:vps / start.sh with LOW_MEMORY_BUILD=1 on 1-2 GB RAM VPS
# LOW_MEMORY_BUILD=1
